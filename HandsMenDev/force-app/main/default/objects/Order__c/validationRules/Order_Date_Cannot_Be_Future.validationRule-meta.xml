<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Order_Date_Cannot_Be_Future</fullName>
    <active>true</active>
    <errorConditionFormula>Order_Date__c &gt; TODAY()</errorConditionFormula>
